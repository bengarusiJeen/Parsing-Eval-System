# Backend environment template — copy to backend/.env and fill in real values.
# backend/.env is gitignored; do NOT commit real credentials.

# Jeen parser service (single endpoint; parser_method chosen at call time)
PARSER_URL=http://localhost:4004/api/v1/parser/parse

# Azure OCR (used by the GT image pre-check)
AZURE_OCR_KEY=
AZURE_OCR_ENDPOINT=

# PostgreSQL — required for the evaluation history feature.
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/Parser_Evaluation_System?sslmode=require
